APP_SCHEME=http
DEPLOY_DOMAIN=your-server-host-or-domain
DB_USER=postgres
DB_PASSWORD=<change_me>
DB_NAME=grocery
DB_PORT_EXTERNAL=5432
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_PORT_EXTERNAL=8000
BACKEND_PORT=8000
BACKEND_PORT_EXTERNAL=8080
FRONTEND_PORT_EXTERNAL=80
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DEPLOY_DOMAIN}:${DB_PORT_EXTERNAL}/${DB_NAME}
GEMINI_API_KEY=<your_gemini_api_key_here>
GEMINI_ROUTING_MODEL=gemini-2.5-flash
GEMINI_PLANNING_MODEL=gemini-2.5-flash-lite
GEMINI_SQL_MODEL=gemini-2.5-flash
GEMINI_RESPONSE_MODEL=gemini-2.5-flash-lite
GEMINI_RECEIPT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONALITY=768
VITE_API_URL=
VITE_API_SCHEME=${APP_SCHEME}
VITE_API_HOST=${DEPLOY_DOMAIN}
VITE_API_PORT=${BACKEND_PORT_EXTERNAL}
CORS_ALLOWED_ORIGINS=${APP_SCHEME}://${DEPLOY_DOMAIN}
CORS_ALLOW_ORIGIN_REGEX=

# Variable notes
# APP_SCHEME: Public protocol used by the deployed app, typically http or https.
# DEPLOY_DOMAIN: Public IP or domain name that users open in the browser.
# DB_USER: PostgreSQL username for the app database.
# DB_PASSWORD: PostgreSQL password for the app database user.
# DB_NAME: PostgreSQL database name used by the backend.
# DB_PORT_EXTERNAL: Host machine port exposed for PostgreSQL access.
# CHROMA_HOST: Chroma host used by the backend service.
# CHROMA_PORT: Internal Chroma port used by the backend service.
# CHROMA_PORT_EXTERNAL: Host machine port exposed for Chroma.
# BACKEND_PORT: Internal FastAPI port inside the backend container/process.
# BACKEND_PORT_EXTERNAL: Host machine port exposed for the backend API.
# FRONTEND_PORT_EXTERNAL: Host machine port exposed for the frontend UI.
# DATABASE_URL: Manual-run database connection string for the FastAPI backend.
# GEMINI_API_KEY: API key used for Gemini calls across receipt parsing and chat.
# GEMINI_ROUTING_MODEL: Gemini model used to classify request intent.
# GEMINI_PLANNING_MODEL: Gemini model used to plan the RAG workflow.
# GEMINI_SQL_MODEL: Gemini model used to generate SQL queries.
# GEMINI_RESPONSE_MODEL: Gemini model used to compose final user-facing answers and fallbacks.
# GEMINI_RECEIPT_MODEL: Primary Gemini model used to extract structured receipt data.
# GEMINI_EMBEDDING_MODEL: Gemini embedding model used for semantic search.
# GEMINI_EMBEDDING_DIMENSIONALITY: Output vector size expected by the vector store.
# VITE_API_URL: Optional full frontend API URL override. Leave empty to compose from scheme, host, and port.
# VITE_API_SCHEME: Protocol the frontend should use when building the backend API URL.
# VITE_API_HOST: Public backend hostname or IP used by the frontend in the browser.
# VITE_API_PORT: Public backend port used by the frontend API requests.
# CORS_ALLOWED_ORIGINS: Comma-separated browser origins allowed to call the backend API.
# CORS_ALLOW_ORIGIN_REGEX: Optional regex alternative for dynamic origin matching.
